# Required
GEMINI_API_KEY=paste_your_key_here

# Optional
GEMINI_MODEL=gemini-2.5-pro
PORT=3000

# OCR provider: 'gemini' (vision does OCR + answer in one call — recommended)
#            or 'ocrspace' (OCR.space extracts text, Gemini writes answer)
OCR_PROVIDER=gemini
OCR_SPACE_API_KEY=helloworld

# Production (Vercel) only — set these in Vercel dashboard, not in .env
# ALLOWED_ORIGIN=https://your-app.vercel.app
# TRUST_PROXY=1
