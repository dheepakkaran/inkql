# AI provider — 'openai' (recommended, uses gpt-4o-mini vision) or 'gemini'
AI_PROVIDER=openai

# OpenAI (only if AI_PROVIDER=openai)
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini

# Gemini (only if AI_PROVIDER=gemini, or as fallback text-mode partner)
GEMINI_API_KEY=paste_your_key_here
GEMINI_MODEL=gemini-2.5-flash

PORT=3000

# OCR provider (only relevant when AI_PROVIDER=gemini):
#   'gemini'   — vision does OCR + answer in one call (recommended)
#   'ocrspace' — OCR.space extracts text, Gemini writes answer
OCR_PROVIDER=gemini
OCR_SPACE_API_KEY=helloworld

# Production (Vercel) only — set these in Vercel dashboard, not in .env
# ALLOWED_ORIGIN=https://your-app.vercel.app
# TRUST_PROXY=1
